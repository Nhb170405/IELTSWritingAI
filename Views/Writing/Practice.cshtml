@model WritingPracticeViewModel
@{
    ViewData["Title"] = "Practice";
}

<section class="writing-grid">
    <aside class="topic-panel">
        <p class="eyebrow">@Model.TaskType</p>
        <h1>Writing prompt</h1>
        <p>@Model.TopicText</p>
        <a class="button" asp-action="Practice" asp-route-taskType="@Model.TaskType">New random topic</a>
    </aside>

    <section class="editor-panel">
        <div class="editor-head">
            <h2>Your essay</h2>
            <span><strong id="wordCount">0</strong> words</span>
        </div>
        <form asp-action="Submit" method="post" class="stack">
            <input asp-for="TopicId" type="hidden" />
            <input asp-for="TaskType" type="hidden" />
            <input asp-for="TopicText" type="hidden" />
            <textarea asp-for="EssayText" id="essayText" rows="20" placeholder="Write your essay here..."></textarea>
            <span asp-validation-for="EssayText" class="validation"></span>
            <button class="primary" type="submit">Submit for scoring</button>
        </form>
    </section>
</section>

@section Scripts {
    <script src="~/js/word-count.js" asp-append-version="true"></script>
}

@model IReadOnlyList<Submission>
@{
    ViewData["Title"] = "Dashboard";
}

<section class="dashboard-head">
    <div>
        <p class="eyebrow">Writing practice</p>
        <h1>Choose a task and start writing</h1>
    </div>
    <div class="actions">
        <a class="button primary" asp-action="Practice" asp-route-taskType="Task2">Random Task 2</a>
        <a class="button" asp-action="Practice" asp-route-taskType="Task1">Random Task 1</a>
    </div>
</section>

<section class="history">
    <h2>Recent submissions</h2>
    @if (Model.Count == 0)
    {
        <p class="muted">No submissions yet.</p>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Task</th>
                        <th>Words</th>
                        <th>Overall</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CreatedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.Topic?.TaskType</td>
                        <td>@item.WordCount</td>
                        <td><strong>@item.OverallScore</strong></td>
                        <td><a asp-action="Result" asp-route-id="@item.Id">Open</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

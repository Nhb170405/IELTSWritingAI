@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<section class="auth-panel">
    <h1>Create account</h1>
    <form asp-action="Register" method="post" class="stack">
        <div asp-validation-summary="ModelOnly" class="validation"></div>
        <label>
            Email
            <input asp-for="Email" autocomplete="email" />
            <span asp-validation-for="Email" class="validation"></span>
        </label>
        <label>
            Password
            <input asp-for="Password" autocomplete="new-password" />
            <span asp-validation-for="Password" class="validation"></span>
        </label>
        <button class="primary" type="submit">Register</button>
    </form>
    <p class="muted">Already have an account? <a asp-action="Login">Login</a></p>
</section>

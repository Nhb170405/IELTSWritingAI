@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<section class="auth-panel">
    <h1>Login</h1>
    <form asp-action="Login" method="post" class="stack">
        <div asp-validation-summary="ModelOnly" class="validation"></div>
        <label>
            Email
            <input asp-for="Email" autocomplete="email" />
            <span asp-validation-for="Email" class="validation"></span>
        </label>
        <label>
            Password
            <input asp-for="Password" autocomplete="current-password" />
            <span asp-validation-for="Password" class="validation"></span>
        </label>
        <button class="primary" type="submit">Login</button>
    </form>
    <p class="muted">New here? <a asp-action="Register">Create an account</a></p>
</section>
